{
  "name": "tally-landing",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:clock": "npm --prefix apps/clock run dev",
    "build": "npm run build:clock && next build",
    "build:clock": "npm --prefix apps/clock ci && npm --prefix apps/clock run build",
    "start": "next start",
    "test": "vitest run",
    "sync:tools": "./scripts/sync-tools.sh"
  },
  "dependencies": {
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.36.2",
    "next": "^15.5.12",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.1.4",
    "vitest": "^4.0.18"
  }
}
